OPENAI_API_KEY=#TBD: Add your OpenAI API key here
CHROMA_DB_PATH=./chroma_db
UPLOADS_PATH=./uploads
MAX_FILE_SIZE_MB=50
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
EMBEDDING_MODEL=text-embedding-3-large
CHAT_MODEL=gpt-5.2-chat-latest
LIGHT_MODEL=o4-mini
# modello long context
LONG_CONTEXT_MODEL=gpt-4.1

# CORS
ALLOWED_ORIGINS=["http://localhost:5172","http://127.0.0.1:5172","http://localhost:3000"]

# RAG Pipeline
DEFAULT_TOP_K=8
MAX_CONTEXT_TOKENS=3000
MAX_CONTINUATIONS=5

# Embedding
MAX_EMBEDDING_TOKENS=8000
EMBEDDING_CACHE_SIZE=1000

# Query Router Thresholds
HIGH_RELEVANCE_THRESHOLD=0.85
LOW_RELEVANCE_THRESHOLD=0.35

# LLM Parameters
COMPRESSION_TEMPERATURE=0
TITLE_TEMPERATURE=1
TITLE_MAX_TOKENS=20

# Prompts (multiline defaults are in config.py — override here if needed)
# CHAT_SYSTEM_PROMPT=
# CHAT_USER_PROMPT_TEMPLATE=
# CHAT_STREAMING_SYSTEM_PROMPT=
# CHAT_STREAMING_USER_PROMPT_TEMPLATE=
